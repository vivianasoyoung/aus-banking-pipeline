# Copy to .env and fill in real values. Never commit .env.

# Postgres password (used by Airflow metadata DB and the pipeline DB)
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Airflow webserver session signing key
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_SECRET_KEY=replace-with-64-char-hex-string

# Airflow Fernet key for encrypting connections + variables
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=replace-with-fernet-key
